Options -Indexes
RewriteEngine On
RewriteBase /

# Serve real static files directly (assets, uploads, js, css, images, etc.)
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# Route ALL other requests (including /admin/*, /chatapp/* etc.) through index.php
RewriteRule ^(.*)$ index.php [QSA,L]
